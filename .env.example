DATABASE_URL="file:./dev.db"

# ─── Oracle Database (production) ───────────────────────────────────────────
# Use ORACLE_SERVICE_NAME or ORACLE_SID (not both required; SID takes precedence)
ORACLE_HOST="localhost"
ORACLE_PORT="1521"
ORACLE_SERVICE_NAME="ORCL"
# ORACLE_SID="ORCL"
ORACLE_USER=""
ORACLE_PASSWORD=""
ORACLE_SCHEMA="IAS20251"
ORACLE_POOL_MIN="1"
ORACLE_POOL_MAX="10"
ORACLE_POOL_INCREMENT="1"

# Database provider: sqlite (default dev) | oracle (production)
# DATABASE_PROVIDER="sqlite"

NEXTAUTH_SECRET="change-this-to-random-secret-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Oracle Database (IAS / APS — migration target) ───────────────────────
# When ORACLE_USER is set, repositories can use Oracle; Prisma/SQLite remains fallback.
ORACLE_HOST="localhost"
ORACLE_PORT="1521"
ORACLE_SERVICE_NAME="ORCL"
ORACLE_USER=""
ORACLE_PASSWORD=""
ORACLE_SCHEMA="IAS20251"
ORACLE_POOL_MIN="1"
ORACLE_POOL_MAX="10"
ORACLE_POOL_INCREMENT="1"

# ─── واتساب ───────────────────────────────────────────────────────────────
# الإرسال اليدوي (زر «فتح واتساب») يعمل بدون أي إعداد هنا.
# الإعدادات أدناه مطلوبة فقط للإرسال التلقائي من الخادم (WhatsApp Cloud API).

# رمز الدولة الافتراضي لتحويل الأرقام المحلية (مثال: 773084555 → +967773084555)
WHATSAPP_DEFAULT_COUNTRY_CODE="967"

# ─── إرسال تلقائي (اختياري — WhatsApp Cloud API) ─────────────────────────
WHATSAPP_CLOUD_API_TOKEN=""
 WHATSAPP_PHONE_NUMBER_ID="123456789012345"
# WHATSAPP_AUTO_NOTIFY="true"

# رقم افتراضي للمستلم إن لم يُحدد رقم المورد أو المستخدم (اختياري)
# WHATSAPP_DEFAULT_RECIPIENT=""

