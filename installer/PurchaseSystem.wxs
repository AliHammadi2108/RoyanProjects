<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define ProductName = "نظام المشتريات" ?>
  <?define ProductFolder = "PurchaseWebSystem" ?>
  <Product
    Id="*"
    Name="$(var.ProductName)"
    Language="1025"
    Version="1.0.0.0"
    Manufacturer="PurchaseWebSystem"
    UpgradeCode="A7B3C4D5-E6F7-4890-ABCD-EF1234567890">
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="Purchase Web System - Next.js purchase management"
      Comments="Requires Node.js 20+ for post-install setup" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Purchase Web System is already installed."
      AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <UIRef Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.InstallerRoot)assets\License.rtf" />

    <Feature Id="MainFeature" Title="Purchase Web System" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PostInstallRegistry" />
    </Feature>

    <CustomAction
      Id="RunPostInstall"
      Directory="INSTALLFOLDER"
      ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]installer\post-install.ps1&quot; -InstallDir &quot;[INSTALLFOLDER]&quot; "
      Execute="commit" Impersonate="yes" Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom Action="RunPostInstall" After="InstallFiles">NOT REMOVE</Custom>
    </InstallExecuteSequence>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="$(var.ProductFolder)" />
      </Directory>
    </Directory>

    <Component Id="PostInstallRegistry" Directory="INSTALLFOLDER" Guid="B1C2D3E4-F5A6-4789-B012-3456789ABCDE">
      <RegistryValue
        Root="HKLM"
        Key="Software\PurchaseWebSystem"
        Name="InstallPath"
        Type="string"
        Value="[INSTALLFOLDER]"
        KeyPath="yes" />
    </Component>
  </Product>
</Wix>

